# Copy to terraform.tfvars and fill in. (terraform.tfvars is gitignored.)

allowed_cidr = "REPLACE_WITH_YOUR_IP/32" # find it: curl ifconfig.me
key_name     = "your-ec2-key-pair"       # an existing EC2 key pair name
repo_url     = "https://github.com/GYOM15/rag-vector-hybrid-graph.git"

# Optional overrides:
# region        = "us-east-1"
# instance_type = "g5.xlarge"
# model         = "Qwen/Qwen2.5-7B-Instruct"

# Ray Serve autoscaling variant (needs a multi-GPU instance):
# serving_mode  = "ray"
# instance_type = "g5.12xlarge"   # 4x A10G -> up to 4 autoscaled replicas
