# Copie ce fichier en `.env` et remplis les valeurs voulues.
# `.env` est chargé automatiquement par l'app et le benchmark.

# --- Backend LLM pour la GÉNÉRATION (les 3 stacks) ---
LLM_PROVIDER=ollama                 # ollama | openai | huggingface
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
HF_MODEL=google/flan-t5-base

# --- OpenAI ---
# Requis par RAGAS (le benchmark s'en sert comme LLM-juge).
# Sert aussi à la génération si LLM_PROVIDER=openai.
OPENAI_API_KEY=

# Laisser commenté pour le VRAI OpenAI (RAGAS).
# Décommenter et pointer vers un serveur vLLM uniquement pour la génération.
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_MODEL=gpt-4o-mini
